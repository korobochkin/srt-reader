{
  "group": {
    "default": {
      "targets": [
        "tests-runner-integration",
        "tests-runner-unit"
      ]
    }
  },
  "target": {
    "tests-runner-integration": {
      "context": ".",
      "dockerfile": "./development/php/Dockerfile",
      "args": {
        "GID": "1001",
        "UID": "1001"
      },
      "tags": [
        "srt-reader-tests-runner-integration:latest"
      ],
      "cache-from": [
        {
          "type": "gha"
        }
      ],
      "cache-to": [
        {
          "mode": "max",
          "type": "gha"
        }
      ],
      "target": "tests-runner-integraion",
      "output": [
        {
          "type": "docker"
        }
      ]
    },
    "tests-runner-unit": {
      "context": ".",
      "dockerfile": "./development/php/Dockerfile",
      "args": {
        "GID": "1001",
        "UID": "1001"
      },
      "tags": [
        "srt-reader-tests-runner-unit:latest"
      ],
      "cache-from": [
        {
          "type": "gha"
        }
      ],
      "cache-to": [
        {
          "mode": "max",
          "type": "gha"
        }
      ],
      "target": "tests-runner-unit",
      "output": [
        {
          "type": "docker"
        }
      ]
    }
  }
}
